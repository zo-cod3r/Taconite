# TACONITE APP - FINAL VERSION

# 1. Load Required .NET Assemblies
Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing
Add-Type -AssemblyName System.ComponentModel

# 2. Define Global File Paths
$signinLogPath = "$PSScriptRoot\signin_log.txt"
$accountsFilePath = "$PSScriptRoot\accounts.txt"
$cutterLogPath = "$PSScriptRoot\cutter_movements_log.txt"
$cutterStatusPath = "$PSScriptRoot\cutter_status.txt"
$operationsFilePath = "$PSScriptRoot\cutter_operations.txt"
$pocHoursTaconitePath = "$PSScriptRoot\poc_hours_taconite.txt"
$pocHoursCoalShovelPath = "$PSScriptRoot\poc_hours_coalshovel.txt"
$cutterOperationUpdateLogPath = "$PSScriptRoot\CutterOperationUpdate_log.txt"

# 3. Helper Functions (Data Management)

function Get-Accounts {
    $accounts = @{}; if (Test-Path $accountsFilePath) { Get-Content $accountsFilePath | ForEach-Object { $parts = $_ -split "\|"; if ($parts.Length -eq 2) { $accounts[$parts[0].Trim()] = $parts[1].Trim() } } }; return $accounts
}

function Save-Account($username, $password) {
    Add-Content -Path $accountsFilePath -Value "$username|$password"
}

function Log-Attempt($username, $password, $status) {
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"; $logEntry = "[$timestamp] Username: $username | Password: $password | Status: $status"; Add-Content -Path $signinLogPath -Value $logEntry
}

function Log-CutterUpdate($username, $vessel, $newStatus) {
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"; $logEntry = "[$timestamp] User: $username | Vessel: $vessel | Updated Status To: $newStatus"; Add-Content -Path $cutterLogPath -Value $logEntry
}

function Log-OperationAssignment($username, $cutter, $operation) {
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"; $logEntry = "[$timestamp] User: $username | Assigned Cutter: $cutter to Operation: $operation"; Add-Content -Path $cutterOperationUpdateLogPath -Value $logEntry
}

function Save-PocHourEntry($username, $eventDate, $operation, $cutter, $hourType, $hours, [string]$location = "") {
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"; $eventDateString = $eventDate.ToString("yyyy-MM-dd")
    $logEntry = "$timestamp|$username|$eventDateString|$location|$cutter|$hourType|$hours"
    $targetPath = if ($operation -eq "Operation TACONITE") { $pocHoursTaconitePath } else { $pocHoursCoalShovelPath }
    Add-Content -Path $targetPath -Value $logEntry
}

function Get-PocHourEntries($operation) {
    $entries = New-Object System.ComponentModel.BindingList[PSObject]
    $pathsToRead = @()
    if ($operation -eq "Operation TACONITE") { $pathsToRead += $pocHoursTaconitePath }
    elseif ($operation -eq "Operation COAL SHOVEL") { $pathsToRead += $pocHoursCoalShovelPath }
    elseif ($operation -eq "All Operations") { $pathsToRead += $pocHoursTaconitePath; $pathsToRead += $pocHoursCoalShovelPath }
    foreach ($path in $pathsToRead) {
        if (Test-Path $path) {
            Get-Content $path | ForEach-Object {
                $parts = $_ -split '\|'; if ($parts.Length -eq 7) {
                    $entries.Add([PSCustomObject]@{ Timestamp = $parts[0].Trim(); User = $parts[1].Trim(); EventDate = [datetime]$parts[2].Trim(); Location = $parts[3].Trim(); Cutter = $parts[4].Trim(); HourType = $parts[5].Trim(); Hours = [double]$parts[6].Trim() })
                }
            }
        }
    }
    return $entries
}

function Get-CutterStatuses {
    $statuses = @{}; if (Test-Path $cutterStatusPath) { Get-Content $cutterStatusPath | ForEach-Object { $parts = $_ -split "\|", 4; if ($parts.Length -eq 4) { $statuses[$parts[0].Trim()] = @{ Status = $parts[1].Trim(); Timestamp = $parts[2].Trim(); User = $parts[3].Trim() } } } }; return $statuses
}

function Save-CutterStatus($vessel, $status, $currentUser) {
    $statuses = Get-CutterStatuses; $timestamp = Get-Date -Format "MM/dd/yy HH:mm"; $statuses[$vessel] = @{ Status = $status; Timestamp = $timestamp; User = $currentUser }
    $lines = @(); $sortedKeys = $statuses.Keys | Sort-Object; foreach ($key in $sortedKeys) { $statusEntry = $statuses[$key]; $lines += "$key|$($statusEntry.Status)|$($statusEntry.Timestamp)|$($statusEntry.User)" }; Set-Content -Path $cutterStatusPath -Value $lines
}

function Get-CutterOperations {
    $assignments = @{}; $defaultAssignments = @{ "CGC MACKINAW" = "Operation TACONITE"; "CGC SPAR" = "Operation TACONITE"; "CGC BISCAYNE BAY" = "Operation TACONITE"; "CGC MOBILE BAY" = "Operation TACONITE"; "CGC KATMAI BAY" = "Operation COAL SHOVEL"; "CGC NEAH BAY" = "Operation COAL SHOVEL"; "CGC BRISTOL BAY" = "Operation COAL SHOVEL" }
    if (Test-Path $operationsFilePath) { Get-Content $operationsFilePath | ForEach-Object { $parts = $_ -split '\|'; if ($parts.Length -eq 2) { $assignments[$parts[0].Trim()] = $parts[1].Trim() } }; return $assignments }
    else { Save-CutterOperations $defaultAssignments; return $defaultAssignments }
}

function Save-CutterOperations($assignments) {
    $lines = @(); $sortedKeys = $assignments.Keys | Sort-Object; foreach ($key in $sortedKeys) { $lines += "$key|$($assignments[$key])" }; Set-Content -Path $operationsFilePath -Value $lines
}

