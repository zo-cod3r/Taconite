# TACONITE APP

# 1. Load Assemblies
Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

# 2. Define File Paths (Robust Method)
# This ensures data files are always in the same folder as the script.
$scriptPath = if ($PSScriptRoot) { $PSScriptRoot } else { Split-Path -Path $MyInvocation.MyCommand.Definition -Parent }
$logFilePath = Join-Path $scriptPath "taconite_log.txt"
$accountsFilePath = Join-Path $scriptPath "taconite_accounts.txt"
$cutterLogPath = Join-Path $scriptPath "cutter_movements_log.txt"
$cutterStatusPath = Join-Path $scriptPath "cutter_status.txt"
$pocHoursPath = Join-Path $scriptPath "poc_hours.txt"

# 3. Helper Functions
function Get-Accounts {
    $accounts = @{}
    if (Test-Path $accountsFilePath) {
        Get-Content $accountsFilePath | ForEach-Object {
            $parts = $_ -split "\|"
            if ($parts.Length -eq 2) {
                $accounts[$parts[0].Trim()] = $parts[1].Trim()
            }
        }
    }
    return $accounts
}

function Save-Account($username, $password) {
    Add-Content -Path $accountsFilePath -Value "$username|$password"
}

function Log-Attempt($username, $password, $status) {
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $logEntry = "[$timestamp] Username: $username | Password: $password | Status: $status"
    Add-Content -Path $logFilePath -Value $logEntry
}

function Log-CutterUpdate($username, $vessel, $newStatus) {
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $logEntry = "[$timestamp] User: $username | Vessel: $vessel | Updated Status To: $newStatus"
    Add-Content -Path $cutterLogPath -Value $logEntry
}

function Save-PocHourEntry($username, $cutter, $hourType, $hours) {
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $logEntry = "$timestamp|$username|$cutter|$hourType|$hours"
    Add-Content -Path $pocHoursPath -Value $logEntry
}

# ADDED: Function to read and aggregate the total hours from the POC hours log.
function Get-AggregatedPocHours {
    $cutters = @("CGC MACKINAW", "CGC SPAR", "CGC KATMAI BAY", "CGC MOBILE BAY", "CGC BISCAYNE BAY", "CGC NEAH BAY", "CGC BRISTOL BAY")
    $hourTypes = @("VA", "DA", "PI", "MC")
    
    # Initialize a nested hashtable to store the totals
    $totals = @{}
    foreach ($cutter in $cutters) {
        $totals[$cutter] = @{}
        foreach ($type in $hourTypes) {
            $totals[$cutter][$type] = 0.0
        }
    }

    if (Test-Path $pocHoursPath) {
        Get-Content $pocHoursPath | ForEach-Object {
            $parts = $_ -split "\|"
            if ($parts.Length -eq 5) {
                $cutterName = $parts[2].Trim()
                $hourType = $parts[3].Trim()
                $hoursString = $parts[4].Trim()
                $hoursValue = 0.0
                
                # Use InvariantCulture to ensure '.' is always the decimal separator, preventing regional issues.
                $culture = [System.Globalization.CultureInfo]::InvariantCulture
                if ([double]::TryParse($hoursString, [System.Globalization.NumberStyles]::Any, $culture, [ref]$hoursValue)) {
                    if ($totals.ContainsKey($cutterName) -and $totals[$cutterName].ContainsKey($hourType)) {
                        $totals[$cutterName][$hourType] += $hoursValue
                    }
                }
            }
        }
    }
    return $totals
}


function Get-CutterStatuses {
    $statuses = @{}
    if (Test-Path $cutterStatusPath) {
        Get-Content $cutterStatusPath | ForEach-Object {
            $parts = $_ -split "\|", 4 
            if ($parts.Length -eq 4) {
                $statuses[$parts[0].Trim()] = @{
                    Status = $parts[1].Trim()
                    Timestamp = $parts[2].Trim()
                    User = $parts[3].Trim()
                }
            }
        }
    }
    return $statuses
}

function Save-CutterStatus($vessel, $status, $currentUser) {
    $statuses = Get-CutterStatuses
    $timestamp = Get-Date -Format "MM/dd/yy HH:mm"
    $statuses[$vessel] = @{
        Status = $status
        Timestamp = $timestamp
        User = $currentUser
    }
    
    $lines = @()
    $sortedKeys = $statuses.Keys | Sort-Object
    foreach ($key in $sortedKeys) {
        $statusEntry = $statuses[$key]
        $lines += "$key|$($statusEntry.Status)|$($statusEntry.Timestamp)|$($statusEntry.User)"
    }
    Set-Content -Path $cutterStatusPath -Value $lines
}

