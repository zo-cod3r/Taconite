            $divider2.BackColor = [System.Drawing.Color]::LightGray
            $homeForm.Controls.Add($divider2)
            # MODIFIED: Adjusted Y position of the logout button
            $logoutButton = New-Object System.Windows.Forms.Button
            $logoutButton.Location = New-Object System.Drawing.Point(140,310)
            $logoutButton.Size = New-Object System.Drawing.Size(100,35)
            $logoutButton.Text = 'Log Out'
