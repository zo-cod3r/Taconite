            $logoutButton.BackColor = [System.Drawing.Color]::DimGray
            $logoutButton.ForeColor = [System.Drawing.Color]::White
            $logoutButton.FlatStyle = [System.Windows.Forms.FlatStyle]::Flat
            $logoutButton.FlatAppearance.BorderSize = 0
