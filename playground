        if ($selectedLocation -and $selectedLocation -ne "All Locations") { $filteredEntries = $filteredEntries | Where-Object { $_.Location -eq $selectedLocation } }
        $getSum = { param($data, $cutterFilter, $typeFilter) return ($data | Where-Object { $_.Cutter -eq $cutterFilter -and $_.HourType -eq $typeFilter } | Measure-Object -Property Hours -Sum).Sum }
        $columnTotals = @{ "VA" = 0; "DA" = 0; "PI" = 0; "MC" = 0 }
        foreach ($cutter in $allCutters) {
