            $statusLabel.Text = 'Please enter username and password.'
            return
        }
        $accounts = Get-Accounts
        if ($accounts.ContainsKey($username) -and $accounts[$username] -eq $password) {
            Log-Attempt $username $password "SUCCESS"
            $form.Hide()
            $homeForm = New-Object System.Windows.Forms.Form
            $homeForm.Text = 'Taconite App - Home'
            # MODIFIED: Increased form height to fit new buttons
            $homeForm.Size = New-Object System.Drawing.Size(400,420)
