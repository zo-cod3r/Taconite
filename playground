# TACONITE APP - FULLY UPDATED

# 1. Load Required .NET Assemblies
# These assemblies provide the necessary classes for creating Windows Forms GUI elements.
Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing
Add-Type -AssemblyName System.ComponentModel # Required for BindingList in the data grid view

# 2. Define Global File Paths
# Using $PSScriptRoot makes the script portable, as it bases all file paths
# on the location of the script itself.
$logFilePath = "$PSScriptRoot\taconite_log.txt"
$accountsFilePath = "$PSScriptRoot\taconite_accounts.txt"
$cutterLogPath = "$PSScriptRoot\cutter_movements_log.txt"
$cutterStatusPath = "$PSScriptRoot\cutter_status.txt"
$pocHoursPath = "$PSScriptRoot\poc_hours.txt"

# 3. Helper Functions (Data Management)

function Get-Accounts {
    # Reads the accounts file and returns a hashtable of username-password pairs.
    $accounts = @{}
    if (Test-Path $accountsFilePath) {
        Get-Content $accountsFilePath | ForEach-Object {
            $parts = $_ -split "\|"
            if ($parts.Length -eq 2) {
                $accounts[$parts[0].Trim()] = $parts[1].Trim()
            }
        }
    }
    return $accounts
}

function Save-Account($username, $password) {
    # Appends a new user account to the accounts file.
    Add-Content -Path $accountsFilePath -Value "$username|$password"
}

function Log-Attempt($username, $password, $status) {
    # Logs a login, logout, or account creation attempt to the main log file.
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $logEntry = "[$timestamp] Username: $username | Password: $password | Status: $status"
    Add-Content -Path $logFilePath -Value $logEntry
}

function Log-CutterUpdate($username, $vessel, $newStatus) {
    # Logs when a user updates a cutter's status.
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $logEntry = "[$timestamp] User: $username | Vessel: $vessel | Updated Status To: $newStatus"
    Add-Content -Path $cutterLogPath -Value $logEntry
}

function Save-PocHourEntry($username, $eventDate, $cutter, $hourType, $hours) {
    # Saves a new POC hour entry with the specific date the hours occurred.
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss" # This is the entry timestamp
    $eventDateString = $eventDate.ToString("yyyy-MM-dd") # Format the event date consistently

    # MODIFIED FORMAT: TIMESTAMP|USER|EVENT_DATE|CUTTER|HOUR_TYPE|HOURS
    $logEntry = "$timestamp|$username|$eventDateString|$cutter|$hourType|$hours"
    Add-Content -Path $pocHoursPath -Value $logEntry
}

function Get-PocHourEntries {
    # MODIFIED: Reads the new file format with 6 columns.
    $entries = New-Object System.ComponentModel.BindingList[PSObject]
    if (Test-Path $pocHoursPath) {
        Get-Content $pocHoursPath | ForEach-Object {
            # MODIFIED FORMAT: TIMESTAMP|USER|EVENT_DATE|CUTTER|HOUR_TYPE|HOURS
            $parts = $_ -split '\|'
            if ($parts.Length -eq 6) { # Now expecting 6 parts
                $entry = [PSCustomObject]@{
                    Timestamp = $parts[0].Trim()
                    User      = $parts[1].Trim()
                    EventDate = [datetime]$parts[2].Trim() # Store as a datetime object
                    Cutter    = $parts[3].Trim()
                    HourType  = $parts[4].Trim()
                    Hours     = [double]$parts[5].Trim()
                }
                $entries.Add($entry)
            }
        }
    }
    return $entries
}

function Get-CutterStatuses {
    # Reads the cutter status file and returns a hashtable with the latest status for each vessel.
    $statuses = @{}
    if (Test-Path $cutterStatusPath) {
        Get-Content $cutterStatusPath | ForEach-Object {
            # File Format: VESSEL|STATUS|TIMESTAMP|USER
            $parts = $_ -split "\|", 4
            if ($parts.Length -eq 4) {
                $statuses[$parts[0].Trim()] = @{
                    Status    = $parts[1].Trim()
                    Timestamp = $parts[2].Trim()
                    User      = $parts[3].Trim()
                }
            }
        }
    }
    return $statuses
}

function Save-CutterStatus($vessel, $status, $currentUser) {
    # Updates a vessel's status and rewrites the entire status file.
    $statuses = Get-CutterStatuses
    $timestamp = Get-Date -Format "MM/dd/yy HH:mm"
    
    # Update or add the new status object in the hashtable
    $statuses[$vessel] = @{
        Status    = $status
        Timestamp = $timestamp
        User      = $currentUser
    }
    
    # Rewrite the entire file with updated statuses to ensure consistency.
    $lines = @()
    # Sort keys to maintain a consistent order in the file.
    $sortedKeys = $statuses.Keys | Sort-Object
    foreach ($key in $sortedKeys) {
        $statusEntry = $statuses[$key]
        $lines += "$key|$($statusEntry.Status)|$($statusEntry.Timestamp)|$($statusEntry.User)"
    }
    Set-Content -Path $cutterStatusPath -Value $lines
}

