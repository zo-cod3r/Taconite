function Show-PocDataViewScreen($parentForm) {
    # Defines the data summary screen with a year filter.
    $viewDataForm = New-Object System.Windows.Forms.Form
    $viewDataForm.Text = 'POC Hours Summary'
    $viewDataForm.Size = New-Object System.Drawing.Size(640, 480)
    $viewDataForm.StartPosition = 'CenterScreen'
    $viewDataForm.BackColor = [System.Drawing.Color]::WhiteSmoke

    # --- Year Filter Controls ---
    $labelYearFilter = New-Object System.Windows.Forms.Label
    $labelYearFilter.Location = New-Object System.Drawing.Point(20, 15)
    $labelYearFilter.Size = New-Object System.Drawing.Size(100, 20)
    $labelYearFilter.Text = "Filter by Year:"
    $labelYearFilter.Font = New-Object System.Drawing.Font("Segoe UI", 10, [System.Drawing.FontStyle]::Bold)
    $viewDataForm.Controls.Add($labelYearFilter)
    $yearComboBox = New-Object System.Windows.Forms.ComboBox
    $yearComboBox.Location = New-Object System.Drawing.Point(130, 12)
    $yearComboBox.Size = New-Object System.Drawing.Size(100, 25)
    $yearComboBox.DropDownStyle = [System.Windows.Forms.ComboBoxStyle]::DropDownList
    $viewDataForm.Controls.Add($yearComboBox)

    # --- Data Grid View ---
    $dataGridView = New-Object System.Windows.Forms.DataGridView
    $dataGridView.Location = New-Object System.Drawing.Point(20, 50)
    $dataGridView.Size = New-Object System.Drawing.Size(580, 320)
    $dataGridView.AllowUserToAddRows = $false
    $dataGridView.ReadOnly = $true
    $dataGridView.AutoSizeColumnsMode = 'AllCells'
    $dataGridView.ColumnHeadersDefaultCellStyle.Font = New-Object System.Drawing.Font('Segoe UI', 10, [System.Drawing.FontStyle]::Bold)
    $dataGridView.DefaultCellStyle.Font = New-Object System.Drawing.Font('Segoe UI', 10)
    $dataGridView.RowHeadersVisible = $false
    $dataGridView.Columns.Add("Cutter", "Cutter")
    $dataGridView.Columns.Add("VA", "VA")
    $dataGridView.Columns.Add("DA", "DA")
    $dataGridView.Columns.Add("PI", "PI")
    $dataGridView.Columns.Add("MC", "MC")
    $dataGridView.Columns.Add("Total", "Cutter Total")
    $dataGridView.Columns["Cutter"].DefaultCellStyle.Font = New-Object System.Drawing.Font('Segoe UI', 10, [System.Drawing.FontStyle]::Bold)
    $viewDataForm.Controls.Add($dataGridView)
    
    # --- Logic to Update Table ---
    $updateTable = {
        param($filteredYear)
        $dataGridView.Rows.Clear()
        $allEntries = Get-PocHourEntries
        if ($filteredYear -and $filteredYear -ne "All Years") {
            $filteredEntries = $allEntries | Where-Object { $_.EventDate.Year -eq $filteredYear }
        } else {
            $filteredEntries = $allEntries
        }
        $cutters = @("CGC MACKINAW", "CGC SPAR", "CGC KATMAI BAY", "CGC MOBILE BAY", "CGC BISCAYNE BAY", "CGC NEAH BAY", "CGC BRISTOL BAY")
        $getSum = { param($data, $cutterFilter, $typeFilter) return ($data | Where-Object { $_.Cutter -eq $cutterFilter -and $_.HourType -eq $typeFilter } | Measure-Object -Property Hours -Sum).Sum }
        $columnTotals = @{ "VA" = 0; "DA" = 0; "PI" = 0; "MC" = 0 }
        foreach ($cutter in $cutters) {
            $va_total = &$getSum -data $filteredEntries -cutterFilter $cutter -typeFilter "VA"
            $da_total = &$getSum -data $filteredEntries -cutterFilter $cutter -typeFilter "DA"
            $pi_total = &$getSum -data $filteredEntries -cutterFilter $cutter -typeFilter "PI"
            $mc_total = &$getSum -data $filteredEntries -cutterFilter $cutter -typeFilter "MC"
            $rowTotal = $va_total + $da_total + $pi_total + $mc_total
            $dataGridView.Rows.Add($cutter, $va_total, $da_total, $pi_total, $mc_total, $rowTotal)
            $columnTotals["VA"] += $va_total; $columnTotals["DA"] += $da_total;
            $columnTotals["PI"] += $pi_total; $columnTotals["MC"] += $mc_total;
        }
        $grandTotal = $columnTotals.Values | Measure-Object -Sum | Select-Object -ExpandProperty Sum
        $dataGridView.Rows.Add("TOTALS", $columnTotals["VA"], $columnTotals["DA"], $columnTotals["PI"], $columnTotals["MC"], $grandTotal)
        $totalsRow = $dataGridView.Rows[$dataGridView.Rows.Count - 1]
        $totalsRow.DefaultCellStyle.Font = New-Object System.Drawing.Font('Segoe UI', 10, [System.Drawing.FontStyle]::Bold)
        $totalsRow.DefaultCellStyle.BackColor = [System.Drawing.Color]::LightGray
    }

    # --- Event Handlers ---
    $yearComboBox.add_SelectedIndexChanged({
        &$updateTable -filteredYear $yearComboBox.SelectedItem
    })
    
    $viewDataForm.add_Load({
        $currentYear = (Get-Date).Year
        $allYears = (Get-PocHourEntries | Select-Object @{N="Year";E={$_.EventDate.Year}} -Unique | Sort-Object Year -Descending).Year
        $yearComboBox.Items.Clear()
        $yearComboBox.Items.Add("All Years")
        if ($allYears) {
            $yearComboBox.Items.AddRange($allYears)
        }
        if ($yearComboBox.Items.Contains($currentYear)) {
            $yearComboBox.SelectedItem = $currentYear
        } else {
            $yearComboBox.SelectedIndex = 0
        }
        &$updateTable -filteredYear $yearComboBox.SelectedItem
    })

    # --- Back Button ---
    $backButton = New-Object System.Windows.Forms.Button
    $backButton.Location = New-Object System.Drawing.Point(265, 385)
    $backButton.Size = New-Object System.Drawing.Size(90, 30)
    $backButton.Text = 'Back'
    $backButton.Font = New-Object System.Drawing.Font("Arial", 10, [System.Drawing.FontStyle]::Bold)
    $backButton.DialogResult = [System.Windows.Forms.DialogResult]::Cancel
    $viewDataForm.Controls.Add($backButton)
    $viewDataForm.CancelButton = $backButton
    
    $viewDataForm.ShowDialog()
}

