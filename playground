            $vmrButton.FlatAppearance.BorderSize = 0
            $homeForm.Controls.Add($vmrButton)
            $cutterButton = New-Object System.Windows.Forms.Button
            $cutterButton.Location = New-Object System.Drawing.Point(210,135)
            $cutterButton.Size = New-Object System.Drawing.Size(130,60)
            $cutterButton.Text = 'Cutter Movements'
            $cutterButton.Font = New-Object System.Drawing.Font("Arial", 11, [System.Drawing.FontStyle]::Bold)
            $cutterButton.BackColor = [System.Drawing.Color]::Firebrick
            $cutterButton.ForeColor = [System.Drawing.Color]::White
            $cutterButton.FlatStyle = [System.Windows.Forms.FlatStyle]::Flat
            $cutterButton.FlatAppearance.BorderSize = 0
            $homeForm.Controls.Add($cutterButton)
