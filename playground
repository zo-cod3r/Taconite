        $viewForm.Controls.Add($rowPanel)

        $nameLabel = New-Object System.Windows.Forms.Label
        $nameLabel.Location = New-Object System.Drawing.Point(10, 5)
        $nameLabel.Size = New-Object System.Drawing.Size(150, 25)
        $nameLabel.Text = $cutterName
        $nameLabel.Font = New-Object System.Drawing.Font("Arial", 9, [System.Drawing.FontStyle]::Bold)
        $nameLabel.TextAlign = [System.Drawing.ContentAlignment]::MiddleLeft
        $rowPanel.Controls.Add($nameLabel)

        for ($j = 0; $j -lt $hourTypes.Length; $j++) {
            $hourType = $hourTypes[$j]
            $dataLabel = New-Object System.Windows.Forms.Label
            $dataLabel.Location = New-Object System.Drawing.Point(($headerStartX - 30) + ($j * $colWidth), 5)
            $dataLabel.Size = New-Object System.Drawing.Size($colWidth, 25)
            $dataLabel.Font = New-Object System.Drawing.Font("Arial", 10)
            $dataLabel.TextAlign = [System.Drawing.ContentAlignment]::MiddleCenter
            
            if ($aggregatedData.ContainsKey($cutterName) -and $aggregatedData[$cutterName].ContainsKey($hourType)) {
                # Format to one decimal place for consistent display
                $dataLabel.Text = $aggregatedData[$cutterName][$hourType].ToString("F1")
            } else {
                $dataLabel.Text = "0.0"
            }
            $rowPanel.Controls.Add($dataLabel)
        }
    }

    $footerY = $gridStartY + ($cutters.Length * $rowHeight) + 15
    $bottomDivider = New-Object System.Windows.Forms.Panel
    $bottomDivider.Location = New-Object System.Drawing.Point(30, $footerY)
    $bottomDivider.Size = New-Object System.Drawing.Size(560, 2)
    $bottomDivider.BackColor = [System.Drawing.Color]::LightGray
    $viewForm.Controls.Add($bottomDivider)

    $backButton = New-Object System.Windows.Forms.Button
    $backButton.Location = New-Object System.Drawing.Point(270, $footerY + 15)
    $backButton.Size = New-Object System.Drawing.Size(80, 30)
    $backButton.Text = 'Back'
    $backButton.Font = New-Object System.Drawing.Font("Arial", 10)
    $backButton.BackColor = [System.Drawing.Color]::DimGray
    $backButton.ForeColor = [System.Drawing.Color]::White
    $backButton.FlatStyle = [System.Windows.Forms.FlatStyle]::Flat
    $backButton.FlatAppearance.BorderSize = 0
    $viewForm.Controls.Add($backButton)
    $backButton.Add_Click({ $viewForm.Close() })

    $viewForm.ShowDialog()
}

