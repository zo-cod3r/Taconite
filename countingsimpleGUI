Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

# Global variable to store the running total
$script:RunningTotal = 0

# Create the form
$form = New-Object System.Windows.Forms.Form
$form.Text = "Running Total Calculator"
$form.Size = New-Object System.Drawing.Size(300, 200)
$form.StartPosition = "CenterScreen"

# Create and configure the input label
$inputLabel = New-Object System.Windows.Forms.Label
$inputLabel.Location = New-Object System.Drawing.Point(10, 20)
$inputLabel.Size = New-Object System.Drawing.Size(260, 20)
$inputLabel.Text = "Enter a number:"
$form.Controls.Add($inputLabel)

# Create and configure the input text box
$inputTextBox = New-Object System.Windows.Forms.TextBox
$inputTextBox.Location = New-Object System.Drawing.Point(10, 40)
$inputTextBox.Size = New-Object System.Drawing.Size(260, 20)
$form.Controls.Add($inputTextBox)

# Create and configure the total label
$totalLabel = New-Object System.Windows.Forms.Label
$totalLabel.Location = New-Object System.Drawing.Point(10, 100)
$totalLabel.Size = New-Object System.Drawing.Size(260, 20)
$totalLabel.Text = "Running Total: 0"
$form.Controls.Add($totalLabel)

# Create the button and define its action
$addButton = New-Object System.Windows.Forms.Button
$addButton.Location = New-Object System.Drawing.Point(10, 70)
$addButton.Size = New-Object System.Drawing.Size(120, 30)
$addButton.Text = "Add Number"
$addButton.Add_Click({
    if ($inputTextBox.Text -match '^-?\d+(\.\d+)?$') {
        $numberToAdd = [double]$inputTextBox.Text
        $script:RunningTotal += $numberToAdd
        $totalLabel.Text = "Running Total: $script:RunningTotal"
        $inputTextBox.Text = ""
    }
    else {
        [System.Windows.Forms.MessageBox]::Show("Please enter a valid numeric value.", "Invalid Input", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Warning) | Out-Null
    }
})
$form.Controls.Add($addButton)

# Add an event handler to focus the input text box when the form is activated
$form.Add_Activated({
    $form.ActiveControl = $inputTextBox
})

# Display the form
$form.ShowDialog() | Out-Null
