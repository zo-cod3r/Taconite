# 6. Show Login Form Function
# ---MODIFIED---
# This function now returns the username on success, or $null on failure/cancel.
function Show-LoginForm {
    $form = New-Object System.Windows.Forms.Form
    $form.Text = 'Taconite App - Login'
    $form.Size = New-Object System.Drawing.Size(300,230)
    $form.StartPosition = 'CenterScreen'
    # ... (rest of form setup is the same)
        $labelUsername = New-Object System.Windows.Forms.Label
    $labelUsername.Location = New-Object System.Drawing.Point(10,20)
    $labelUsername.Size = New-Object System.Drawing.Size(280,20)
    $labelUsername.Text = 'Username:'
    $form.Controls.Add($labelUsername)
    $textBoxUsername = New-Object System.Windows.Forms.TextBox
    $textBoxUsername.Location = New-Object System.Drawing.Point(10,40)
    $textBoxUsername.Size = New-Object System.Drawing.Size(260,20)
    $form.Controls.Add($textBoxUsername)
    $labelPassword = New-Object System.Windows.Forms.Label
    $labelPassword.Location = New-Object System.Drawing.Point(10,70)
    $labelPassword.Size = New-Object System.Drawing.Size(280,20)
    $labelPassword.Text = 'Password:'
    $form.Controls.Add($labelPassword)
    $textBoxPassword = New-Object System.Windows.Forms.TextBox
    $textBoxPassword.Location = New-Object System.Drawing.Point(10,90)
    $textBoxPassword.Size = New-Object System.Drawing.Size(260,20)
    $textBoxPassword.PasswordChar = '*'
    $form.Controls.Add($textBoxPassword)
    $loginButton = New-Object System.Windows.Forms.Button
    $loginButton.Location = New-Object System.Drawing.Point(10,125)
    $loginButton.Size = New-Object System.Drawing.Size(80,30)
    $loginButton.Text = 'Login'
    $form.Controls.Add($loginButton)
    $createButton = New-Object System.Windows.Forms.Button
    $createButton.Location = New-Object System.Drawing.Point(100,125)
    $createButton.Size = New-Object System.Drawing.Size(110,30)
    $createButton.Text = 'Create Account'
    $form.Controls.Add($createButton)
    $statusLabel = New-Object System.Windows.Forms.Label
    $statusLabel.Location = New-Object System.Drawing.Point(10,165)
    $statusLabel.Size = New-Object System.Drawing.Size(260,30)
    $statusLabel.ForeColor = [System.Drawing.Color]::Red
    $form.Controls.Add($statusLabel)

    $loginButton.Add_Click({
        $username = $textBoxUsername.Text.Trim()
        $password = $textBoxPassword.Text.Trim()
        $accounts = Get-Accounts
        if ($accounts.ContainsKey($username) -and $accounts[$username] -eq $password) {
            Log-Attempt $username $password "SUCCESS"
            # Set DialogResult and close, returning control to the main loop
            $form.DialogResult = [System.Windows.Forms.DialogResult]::OK
            $form.Close()
        } else {
            Log-Attempt $username $password "FAILED"
            $statusLabel.Text = 'Invalid username or password.'
        }
    })
    
    $createButton.Add_Click({
        # ... (create account logic is the same)
        $username = $textBoxUsername.Text.Trim()
        $password = $textBoxPassword.Text.Trim()
        if ($username -eq '' -or $password -eq '') {
            $statusLabel.Text = 'Please enter username and password.'
            return
        }
        $accounts = Get-Accounts
        if ($accounts.ContainsKey($username)) {
            $statusLabel.Text = 'Username already exists.'
            return
        }
        Save-Account $username $password
        $statusLabel.ForeColor = [System.Drawing.Color]::Green
        $statusLabel.Text = "Account created for '$username'!"
        Log-Attempt $username "" "ACCOUNT CREATED"
    })

    $form.Add_Shown({$textBoxUsername.Select()})
    
    # Show the form and check the result
    if ($form.ShowDialog() -eq [System.Windows.Forms.DialogResult]::OK) {
        return $textBoxUsername.Text.Trim()
    } else {
        return $null # User closed the form or cancelled
    }
}

# 7. Start the App
# ---FIXED---
# Application loop to manage forms and prevent memory leaks.
while ($true) {
    $loggedInUser = Show-LoginForm
    
    # If user cancels or closes login form, exit script.
    if (-not $loggedInUser) {
        break 
    }
    
    # Show home form. If user logs out, the loop continues and shows the login form again.
    $loggedOut = Show-HomeForm -username $loggedInUser
    if (-not $loggedOut) {
        # If the user closes the home form without logging out, exit the app.
        break
    }
}
