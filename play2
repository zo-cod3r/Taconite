            CoalShovel_Checked = $opCoalShovelCheckbox.Checked
            CoalShovel_EtdFrom = $etdInput.Text
            CoalShovel_RequestedDateTime = $reqDateTimeCoalInput.Text
        }
        if ([string]::IsNullOrWhiteSpace($vmrData.VesselName)) { 
            [System.Windows.Forms.MessageBox]::Show("Vessel Name cannot be empty.", "Validation Error")
            return 
        }

        Save-VmrEntry -VmrData $vmrData
        [System.Windows.Forms.MessageBox]::Show("VMR for $($vmrData.VesselName) has been successfully logged.", "Success")
        $vmrForm.Close()
    })
    
    $vmrForm.ShowDialog()
}

