        Save-CutterStatus $selectedVessel $newStatus $currentUser; Log-CutterUpdate $currentUser $selectedVessel $newStatus; $timestampForDisplay = Get-Date -Format "MM/dd/yy HH:mm"; $statusLabels[$selectedVessel].Text = $newStatus; $updateInfoLabels[$selectedVessel].Text = "$timestampForDisplay`n$currentUser"
        $statusInput.Text = "Enter new status..."; $statusInput.ForeColor = [System.Drawing.Color]::Gray; [System.Windows.Forms.MessageBox]::Show("Status for $selectedVessel updated successfully!", "Status Updated")
    }); $assignBtn.Add_Click({
        $selectedVessel = $vesselDropdownAssign.SelectedItem.ToString(); $selectedOp = $operationDropdown.SelectedItem.ToString()
        $assignments = Get-CutterOperations; $assignments[$selectedVessel] = $selectedOp; Save-CutterOperations $assignments
        Log-OperationAssignment $currentUser $selectedVessel $selectedOp
        [System.Windows.Forms.MessageBox]::Show("$selectedVessel has been assigned to $selectedOp.", "Assignment Updated"); &$rebuildDisplay
    }); $cutterForm.Add_Load({ &$rebuildDisplay }); $cutterForm.ShowDialog()
