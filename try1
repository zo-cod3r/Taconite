    $labelActivity.Location = New-Object System.Drawing.Point(30, 130)
    $labelActivity.Font = New-Object System.Drawing.Font("Arial", 10, [System.Drawing.FontStyle]::Bold)
    $entryForm.Controls.Add($labelActivity)

    $activityDropdown = New-Object System.Windows.Forms.ComboBox
    $activityDropdown.Location = New-Object System.Drawing.Point(30, 155)
    $activityDropdown.Size = New-Object System.Drawing.Size(220, 25)
    $activityDropdown.Font = New-Object System.Drawing.Font("Arial", 10)
    $activityDropdown.DropDownStyle = [System.Windows.Forms.ComboBoxStyle]::DropDownList
    $activityDropdown.Items.AddRange($IcebreakingTypes)
    $activityDropdown.SelectedIndex = 0
    $entryForm.Controls.Add($activityDropdown)

    $labelHours = New-Object System.Windows.Forms.Label
    $labelHours.Text = "Hours:"
    $labelHours.Location = New-Object System.Drawing.Point(260, 130)
    $labelHours.Font = New-Object System.Drawing.Font("Arial", 10, [System.Drawing.FontStyle]::Bold)
    $entryForm.Controls.Add($labelHours)

    $hoursInput = New-Object System.Windows.Forms.TextBox
    $hoursInput.Location = New-Object System.Drawing.Point(260, 155)
    $hoursInput.Size = New-Object System.Drawing.Size(110, 25)
    $hoursInput.Font = New-Object System.Drawing.Font("Arial", 10)
    $entryForm.Controls.Add($hoursInput)

    # Submit and Cancel Buttons
    $submitButton = New-Object System.Windows.Forms.Button
    $submitButton.Text = 'Submit'
    $submitButton.Location = New-Object System.Drawing.Point(260, 210)
    $submitButton.Size = New-Object System.Drawing.Size(110, 35)
    $submitButton.Font = New-Object System.Drawing.Font("Arial", 10, [System.Drawing.FontStyle]::Bold)
    $submitButton.BackColor = [System.Drawing.Color]::SeaGreen
    $submitButton.ForeColor = [System.Drawing.Color]::White
    $submitButton.FlatStyle = [System.Windows.Forms.FlatStyle]::Flat
    $entryForm.Controls.Add($submitButton)

    $cancelButton = New-Object System.Windows.Forms.Button
    $cancelButton.Text = 'Cancel'
    $cancelButton.Location = New-Object System.Drawing.Point(140, 210)
    $cancelButton.Size = New-Object System.Drawing.Size(110, 35)
    $cancelButton.Font = New-Object System.Drawing.Font("Arial", 10)
    $cancelButton.BackColor = [System.Drawing.Color]::DimGray
    $cancelButton.ForeColor = [System.Drawing.Color]::White
    $cancelButton.FlatStyle = [System.Windows.Forms.FlatStyle]::Flat
    $entryForm.Controls.Add($cancelButton)

    # --- Event Handlers ---
    $submitButton.Add_Click({
        $selectedVessel = $vesselDropdown.SelectedItem.ToString()
        $selectedActivity = $activityDropdown.SelectedItem.ToString()
        $enteredHours = $hoursInput.Text.Trim()

        # Input Validation
        if ([string]::IsNullOrWhiteSpace($enteredHours)) {
            [System.Windows.Forms.MessageBox]::Show("Please enter the number of hours.", "Input Missing", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Warning)
            return
        }
        if (-not ($enteredHours -match '^\d+(\.\d+)?$')) {
            [System.Windows.Forms.MessageBox]::Show("Please enter a valid number for hours (e.g., 4 or 2.5).", "Invalid Input", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Warning)
            return
        }

        # Save the data and provide feedback
        Save-HourEntry $selectedVessel $selectedActivity ([double]$enteredHours)
        [System.Windows.Forms.MessageBox]::Show("Successfully logged $enteredHours hours for $selectedVessel.", "Entry Saved", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Information)
        
        # Clear the input for the next entry
        $hoursInput.Text = ""
        $vesselDropdown.Focus()
    })

    $cancelButton.Add_Click({
        $entryForm.Close()
    })

    $entryForm.ShowDialog($parentForm)
}

function Show-SummaryForm {
    param($parentForm)

    $summaryForm = New-Object System.Windows.Forms.Form
    $summaryForm.Text = 'Icebreaking Hours Summary'
    $summaryForm.Size = New-Object System.Drawing.Size(780, 520)
    $summaryForm.StartPosition = 'CenterScreen'
    $summaryForm.BackColor = [System.Drawing.Color]::WhiteSmoke

    # --- Controls ---
    $titleLabel = New-Object System.Windows.Forms.Label
    $titleLabel.Text = "HOURS SUMMARY"
    $titleLabel.Location = New-Object System.Drawing.Point(0, 15)
    $titleLabel.Size = New-Object System.Drawing.Size(780, 30)
    $titleLabel.Font = New-Object System.Drawing.Font("Arial", 16, [System.Drawing.FontStyle]::Bold)
    $titleLabel.TextAlign = [System.Drawing.ContentAlignment]::MiddleCenter
    $summaryForm.Controls.Add($titleLabel)

    $divider = New-Object System.Windows.Forms.Panel
    $divider.Location = New-Object System.Drawing.Point(30, 55)
    $divider.Size = New-Object System.Drawing.Size(700, 2)
    $divider.BackColor = [System.Drawing.Color]::LightGray
    $summaryForm.Controls.Add($divider)

    # --- Build Table/Grid ---
    $colWidth = 140
    $headerStartX = 180

    # Column Headers
    for ($i = 0; $i -lt $IcebreakingTypes.Length; $i++) {
        $headerLabel = New-Object System.Windows.Forms.Label
        $headerLabel.Location = New-Object System.Drawing.Point($headerStartX + ($i * $colWidth), 65)
        $headerLabel.Size = New-Object System.Drawing.Size($colWidth, 40) # Taller for word wrap
        $headerLabel.Text = $IcebreakingTypes[$i]
        $headerLabel.Font = New-Object System.Drawing.Font("Arial", 10, [System.Drawing.FontStyle]::Bold)
        $headerLabel.TextAlign = [System.Drawing.ContentAlignment]::MiddleCenter
        $summaryForm.Controls.Add($headerLabel)
    }

    # Header Divider
    $headerDivider = New-Object System.Windows.Forms.Panel
    $headerDivider.Location = New-Object System.Drawing.Point(30, 110)
    $headerDivider.Size = New-Object System.Drawing.Size(700, 2)
    $headerDivider.BackColor = [System.Drawing.Color]::LightGray
    $summaryForm.Controls.Add($headerDivider)

    # Grid Data Rows
    $aggregatedData = Get-AggregatedHours
    $rowHeight = 40
    $gridStartY = 115

    for ($i = 0; $i -lt $Vessels.Length; $i++) {
        $vesselName = $Vessels[$i]
        $rowY = $gridStartY + ($i * $rowHeight)
        
        $rowPanel = New-Object System.Windows.Forms.Panel
        $rowPanel.Location = New-Object System.Drawing.Point(30, $rowY)
        $rowPanel.Size = New-Object System.Drawing.Size(700, $rowHeight)
        $rowPanel.BackColor = if ($i % 2 -eq 0) { [System.Drawing.Color]::White } else { [System.Drawing.Color]::FromArgb(240, 240, 245) }
        $summaryForm.Controls.Add($rowPanel)

        # Vessel Name Label (Row Header)
        $nameLabel = New-Object System.Windows.Forms.Label
        $nameLabel.Location = New-Object System.Drawing.Point(10, 8)
        $nameLabel.Size = New-Object System.Drawing.Size(160, 25)
        $nameLabel.Text = $vesselName
        $nameLabel.Font = New-Object System.Drawing.Font("Arial", 9, [System.Drawing.FontStyle]::Bold)
        $nameLabel.TextAlign = [System.Drawing.ContentAlignment]::MiddleLeft
        $rowPanel.Controls.Add($nameLabel)

        # Data Labels for each activity type
        for ($j = 0; $j -lt $IcebreakingTypes.Length; $j++) {
            $activityType = $IcebreakingTypes[$j]
            $dataLabel = New-Object System.Windows.Forms.Label
            $dataLabel.Location = New-Object System.Drawing.Point(($headerStartX - 30) + ($j * $colWidth), 8)
            $dataLabel.Size = New-Object System.Drawing.Size($colWidth, 25)
            $dataLabel.Font = New-Object System.Drawing.Font("Arial", 10)
            $dataLabel.TextAlign = [System.Drawing.ContentAlignment]::MiddleCenter
            
            # Display the aggregated total, formatted to one decimal place.
            $dataLabel.Text = $aggregatedData[$vesselName][$activityType].ToString("F1")
            $rowPanel.Controls.Add($dataLabel)
        }
    }
    
    # Close Button
    $closeButton = New-Object System.Windows.Forms.Button
    $closeButton.Text = 'Close'
    $closeButton.Location = New-Object System.Drawing.Point(330, 420)
    $closeButton.Size = New-Object System.Drawing.Size(100, 35)
    $closeButton.Font = New-Object System.Drawing.Font("Arial", 10)
    $closeButton.BackColor = [System.Drawing.Color]::DimGray
    $closeButton.ForeColor = [System.Drawing.Color]::White
    $closeButton.FlatStyle = [System.Windows.Forms.FlatStyle]::Flat
    $summaryForm.Controls.Add($closeButton)
    $closeButton.Add_Click({ $summaryForm.Close() })

    $summaryForm.ShowDialog($parentForm)
}

