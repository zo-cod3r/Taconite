    $labelVessel.Size = New-Object System.Drawing.Size(340, 20)
    $labelVessel.Font = New-Object System.Drawing.Font("Arial", 10, [System.Drawing.FontStyle]::Bold)
    $entryForm.Controls.Add($labelVessel)

    $vesselDropdown = New-Object System.Windows.Forms.ComboBox
