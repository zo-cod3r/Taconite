# ICEBREAKING HOURS LOG - TACONITE SEASON

# 1. Load Required .NET Assemblies
Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

# 2. Define Global Variables and File Paths
# This robust method ensures the log file is always in the same folder as the script.
$scriptPath = if ($PSScriptRoot) { $PSScriptRoot } else { Split-Path -Path $MyInvocation.MyCommand.Definition -Parent }
$logFilePath = Join-Path $scriptPath "icebreaking_log.txt"

# Define the master lists for cutters and activities.
$Vessels = @(
    "CGC MACKINAW",
    "CGC SPAR",
    "CGC KATMAI BAY",
    "CGC MOBILE BAY",
    "CGC BISCAYNE BAY",
    "CGC NEAH BAY",
    "CGC BRISTOL BAY"
)
$IcebreakingTypes = @(
    "Direct Icebreaking",
    "Escort Operations",
    "Standby / Preventative",
    "Track Maintenance"
)

# 3. Helper Functions

function Save-HourEntry {
    param(
        [string]$Vessel,
        [string]$ActivityType,
        [double]$Hours
    )
    # The log entry is stored in a simple, pipe-delimited format for easy parsing.
    # FORMAT: Timestamp|Vessel|ActivityType|Hours
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $logEntry = "$timestamp|$Vessel|$ActivityType|$Hours"
    Add-Content -Path $logFilePath -Value $logEntry
}

function Get-AggregatedHours {
    # This function reads the entire log file and calculates the running totals.
    
    # Initialize a nested hashtable to store the totals.
    $totals = @{}
    foreach ($vessel in $Vessels) {
        $totals[$vessel] = @{}
        foreach ($type in $IcebreakingTypes) {
            $totals[$vessel][$type] = 0.0
        }
    }

    # Ensure the log file exists before trying to read it.
    if (Test-Path $logFilePath) {
        Get-Content $logFilePath | ForEach-Object {
            $parts = $_ -split "\|"
            if ($parts.Length -eq 4) {
                $vesselName = $parts[1].Trim()
                $activityType = $parts[2].Trim()
                $hoursString = $parts[3].Trim()
                $hoursValue = 0.0
                
                # Safely convert the hours string to a number, preventing errors from corrupted lines.
                $culture = [System.Globalization.CultureInfo]::InvariantCulture
                if ([double]::TryParse($hoursString, [System.Globalization.NumberStyles]::Any, $culture, [ref]$hoursValue)) {
                    # Check if the keys exist before adding the value.
                    if ($totals.ContainsKey($vesselName) -and $totals[$vesselName].ContainsKey($activityType)) {
                        $totals[$vesselName][$activityType] += $hoursValue
                    }
                }
            }
        }
    }
    return $totals
}


