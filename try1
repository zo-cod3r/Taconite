Add-Type -AssemblyName PresentationFramework, PresentationCore, WindowsBase, System.Windows.Forms

# --- Global Variables ---
[int]$RunningTotal = 0

# --- Function to Handle Addition ---
function Add-Number {
    # Get the value from the input textbox
    $input_value = $txtInput.Text

    # Try to convert the input to a number
    if ([int]::TryParse($input_value, [ref]$number)) {
        # Add to the running total
        $RunningTotal += $number
        # Update the total label
        $lblTotal.Content = "Running Total: $RunningTotal"
        # Clear the input textbox for the next entry
        $txtInput.Text = ""
    }
    else {
        # Show an error message for invalid input
        [System.Windows.MessageBox]::Show("Please enter a valid number.", "Invalid Input", [System.Windows.MessageBoxButton]::OK, [System.Windows.MessageBoxImage]::Warning) | Out-Null
    }
}

# --- Design the GUI (WPF XAML) ---
[xml]$xaml = @"
<Window xmlns="http://schemas.microsoft.com"
        xmlns:x="http://schemas.microsoft.com"
        Title="Running Total Calculator" Height="200" Width="300"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.ColumnSpan="2" Content="Enter a number and click 'Add'" FontSize="14" Margin="0,0,0,10"/>
        
        <TextBox Name="txtInput" Grid.Row="1" Grid.Column="0" Height="25" Margin="0,0,10,0"/>
        
        <Button Name="btnAdd" Grid.Row="1" Grid.Column="1" Content="Add" Width="75" Height="25"/>
        
        <Label Name="lblTotal" Grid.Row="2" Grid.ColumnSpan="2" Content="Running Total: 0" FontSize="16" FontWeight="Bold" Margin="0,20,0,0"/>
    </Grid>
</Window>
"@

# --- Load the GUI and Connect Controls ---
$reader = New-Object System.Xml.XmlNodeReader $xaml
$window = [Windows.Markup.XamlReader]::Load($reader)

# Get references to the controls by their Name attribute
$txtInput = $window.FindName("txtInput")
$btnAdd = $window.FindName("btnAdd")
$lblTotal = $window.FindName("lblTotal")

# Hook up the button click event to the PowerShell function
$btnAdd.Add_Click({ Add-Number })

# Display the window
$window.ShowDialog() | Out-Null
