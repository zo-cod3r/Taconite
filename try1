    $vesselDropdown.Size = New-Object System.Drawing.Size(340, 25)
    $vesselDropdown.Font = New-Object System.Drawing.Font("Arial", 10)
    $vesselDropdown.DropDownStyle = [System.Windows.Forms.ComboBoxStyle]::DropDownList
    $vesselDropdown.Items.AddRange($Vessels)
    $vesselDropdown.SelectedIndex = 0
    $entryForm.Controls.Add($vesselDropdown)

    # Activity & Hours Controls
