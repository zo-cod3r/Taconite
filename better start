            # Cutter Movements placeholder click
            $cutterButton.Add_Click({
                [System.Windows.Forms.MessageBox]::Show("Cutter Movements clicked - feature coming soon!", "Cutter Movements")
            })

            # 7. Logout Button Click Event
            $logoutButton.Add_Click({
                Log-Attempt $username "" "LOGGED OUT"
                $homeForm.Hide()
                [System.Windows.Forms.MessageBox]::Show(
                    "You have successfully logged out.",
                    "Logged Out",
                    [System.Windows.Forms.MessageBoxButtons]::OK,
                    [System.Windows.Forms.MessageBoxIcon]::Information
                )
                $homeForm.Close()
                Show-LoginForm
            })

            $homeForm.ShowDialog()
            $form.Close()

        } else {
            Log-Attempt $username $password "FAILED"
            $statusLabel.Text = 'Invalid username or password.'
        }
    })

    # 8. Create Account Button Click Event
    $createButton.Add_Click({
        $username = $textBoxUsername.Text.Trim()
        $password = $textBoxPassword.Text.Trim()

        if ($username -eq '' -or $password -eq '') {
            $statusLabel.Text = 'Please enter username and password.'
            return
        }

        $accounts = Get-Accounts

        if ($accounts.ContainsKey($username)) {
            $statusLabel.Text = 'Username already exists.'
            return
        }

        Save-Account $username $password
        $statusLabel.ForeColor = [System.Drawing.Color]::Green
        $statusLabel.Text = "Account created for '$username'!"
        Log-Attempt $username $password "ACCOUNT CREATED"
    })

    # 9. Set Focus and Show Form
    $form.Add_Shown({$textBoxUsername.Select()})
    $form.ShowDialog()
}

# 10. Start the App
Show-LoginForm
