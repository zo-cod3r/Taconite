            $logoutButton.Size = New-Object System.Drawing.Size(100,35)
            $logoutButton.Text = 'Log Out'
            $logoutButton.Font = New-Object System.Drawing.Font("Arial", 10, [System.Drawing.FontStyle]::Regular)
            $logoutButton.BackColor = [System.Drawing.Color]::DimGray
            $logoutButton.ForeColor = [System.Drawing.Color]::White
            $logoutButton.FlatStyle = [System.Windows.Forms.FlatStyle]::Flat
            $logoutButton.FlatAppearance.BorderSize = 0
            $homeForm.Controls.Add($logoutButton)

            # VMRs placeholder click
            $vmrButton.Add_Click({
                [System.Windows.Forms.MessageBox]::Show("VMRs clicked - feature coming soon!", "VMRs")
