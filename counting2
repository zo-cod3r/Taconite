# Load necessary assemblies for GUI
Add-Type -AssemblyName System.Windows.Forms;
Add-Type -AssemblyName System.Drawing;

# Global variable to store data using a BindingList for automatic UI updates
$Global:data = New-Object System.ComponentModel.BindingList[PSObject];

# --- Home Screen ---
function Show-HomeScreen {
    $homeForm = New-Object System.Windows.Forms.Form;
    $homeForm.Text = 'Home Screen';
    $homeForm.Size = New-Object System.Drawing.Size(300, 200);
    $homeForm.StartPosition = 'CenterScreen';
    $homeForm.FormBorderStyle = 'FixedDialog';
    $homeForm.MaximizeBox = $false;

    # "Enter Data" button
    $enterDataButton = New-Object System.Windows.Forms.Button;
    $enterDataButton.Location = New-Object System.Drawing.Point(75, 40);
    $enterDataButton.Size = New-Object System.Drawing.Size(130, 40);
    $enterDataButton.Text = 'Enter Data';
    $enterDataButton.Font = New-Object System.Drawing.Font('Segoe UI', 10, [System.Drawing.FontStyle]::Bold);
    $enterDataButton.Add_Click({
        $homeForm.Hide();
        Show-EnterDataScreen;
        $homeForm.Show();
    });
    $homeForm.Controls.Add($enterDataButton);

    # "View Data" button
    $viewDataButton = New-Object System.Windows.Forms.Button;
    $viewDataButton.Location = New-Object System.Drawing.Point(75, 95);
    $viewDataButton.Size = New-Object System.Drawing.Size(130, 40);
    $viewDataButton.Text = 'View Data';
    $viewDataButton.Font = New-Object System.Drawing.Font('Segoe UI', 10, [System.Drawing.FontStyle]::Bold);
    $viewDataButton.Add_Click({
        $homeForm.Hide();
        Show-ViewDataScreen;
        $homeForm.Show();
    });
    $homeForm.Controls.Add($viewDataButton);

    $homeForm.add_FormClosed({$null = $global:data});
    $homeForm.ShowDialog();
}

# --- Enter Data Screen ---
function Show-EnterDataScreen {
    $enterDataForm = New-Object System.Windows.Forms.Form;
    $enterDataForm.Text = 'Enter Data';
    $enterDataForm.Size = New-Object System.Drawing.Size(340, 260);
    $enterDataForm.StartPosition = 'CenterScreen';
    $enterDataForm.FormBorderStyle = 'FixedDialog';
    $enterDataForm.MaximizeBox = $false;

    # Dropdown for MACKINAW/MOBILE
    $label1 = New-Object System.Windows.Forms.Label;
    $label1.Location = New-Object System.Drawing.Point(20, 23);
    $label1.Text = 'Location:';
    $label1.Font = New-Object System.Drawing.Font('Segoe UI', 10);
    $enterDataForm.Controls.Add($label1);

    $locationDropDown = New-Object System.Windows.Forms.ComboBox;
    $locationDropDown.Location = New-Object System.Drawing.Point(120, 20);
    $locationDropDown.Size = New-Object System.Drawing.Size(180, 20);
    $locationDropDown.Items.AddRange(@('MACKINAW', 'MOBILE'));
    $locationDropDown.DropDownStyle = 'DropDownList';
    $locationDropDown.SelectedIndex = 0;
    $locationDropDown.Font = New-Object System.Drawing.Font('Segoe UI', 10);
    $enterDataForm.Controls.Add($locationDropDown);

    # Dropdown for PI/DA
    $label2 = New-Object System.Windows.Forms.Label;
    $label2.Location = New-Object System.Drawing.Point(20, 63);
    $label2.Text = 'Type:';
    $label2.Font = New-Object System.Drawing.Font('Segoe UI', 10);
    $enterDataForm.Controls.Add($label2);

    $typeDropDown = New-Object System.Windows.Forms.ComboBox;
    $typeDropDown.Location = New-Object System.Drawing.Point(120, 60);
    $typeDropDown.Size = New-Object System.Drawing.Size(180, 20);
    $typeDropDown.Items.AddRange(@('PI', 'DA'));
    $typeDropDown.DropDownStyle = 'DropDownList';
    $typeDropDown.SelectedIndex = 0;
    $typeDropDown.Font = New-Object System.Drawing.Font('Segoe UI', 10);
    $enterDataForm.Controls.Add($typeDropDown);

    # Text box for hours
    $label3 = New-Object System.Windows.Forms.Label;
    $label3.Location = New-Object System.Drawing.Point(20, 103);
    $label3.Text = 'Hours:';
    $label3.Font = New-Object System.Drawing.Font('Segoe UI', 10);
    $enterDataForm.Controls.Add($label3);

    $hoursTextBox = New-Object System.Windows.Forms.TextBox;
    $hoursTextBox.Location = New-Object System.Drawing.Point(120, 100);
    $hoursTextBox.Size = New-Object System.Drawing.Size(180, 20);
    $hoursTextBox.Font = New-Object System.Drawing.Font('Segoe UI', 10);
    $enterDataForm.Controls.Add($hoursTextBox);

    # Submit button
    $submitButton = New-Object System.Windows.Forms.Button;
    $submitButton.Location = New-Object System.Drawing.Point(120, 160);
    $submitButton.Size = New-Object System.Drawing.Size(90, 30);
    $submitButton.Text = 'Submit';
    $submitButton.Font = New-Object System.Drawing.Font('Segoe UI', 10, [System.Drawing.FontStyle]::Bold);
    $submitButton.Add_Click({
        $hours = 0;
        if (-not ([int]::TryParse($hoursTextBox.Text, [ref]$hours)) -or $hours -lt 0) {
            [System.Windows.Forms.MessageBox]::Show('Please enter a valid, non-negative number for hours.', 'Invalid Input', 'OK', 'Error');
            return;
        }

        $entry = [PSCustomObject]@{
            Location = $locationDropDown.SelectedItem;
            Type     = $typeDropDown.SelectedItem;
            Hours    = $hours;
        };
        $Global:data.Add($entry);
        [System.Windows.Forms.MessageBox]::Show('Data submitted successfully!', 'Success', 'OK', 'Information');
        $hoursTextBox.Clear();
        $locationDropDown.Focus();
    });
    $enterDataForm.Controls.Add($submitButton);

    # Back button
    $backButton = New-Object System.Windows.Forms.Button;
    $backButton.Location = New-Object System.Drawing.Point(215, 160);
    $backButton.Size = New-Object System.Drawing.Size(85, 30);
    $backButton.Text = 'Back';
    $backButton.Font = New-Object System.Drawing.Font('Segoe UI', 10);
    $backButton.DialogResult = [System.Windows.Forms.DialogResult]::Cancel;
    $enterDataForm.Controls.Add($backButton);
    $enterDataForm.CancelButton = $backButton;

    $enterDataForm.ShowDialog();
}

# --- View Data Screen ---
function Show-ViewDataScreen {
    $viewDataForm = New-Object System.Windows.Forms.Form;
    $viewDataForm.Text = 'Data Summary';
    $viewDataForm.Size = New-Object System.Drawing.Size(380, 320);
    $viewDataForm.StartPosition = 'CenterScreen';
    $viewDataForm.FormBorderStyle = 'FixedDialog';
    $viewDataForm.MaximizeBox = $false;

    # Create a GroupBox for the summary
    $summaryBox = New-Object System.Windows.Forms.GroupBox;
    $summaryBox.Location = New-Object System.Drawing.Point(20, 15);
    $summaryBox.Size = New-Object System.Drawing.Size(320, 215);
    $summaryBox.Text = "Hours Breakdown";
    $summaryBox.Font = New-Object System.Drawing.Font('Segoe UI', 10, [System.Drawing.FontStyle]::Bold);
    $viewDataForm.Controls.Add($summaryBox);

    # --- Labels for displaying totals ---
    $labelFont = New-Object System.Drawing.Font('Segoe UI', 10);
    
    # DEBUG FIX: Initializing complex objects on a single line is safer with semicolons.
    $mackinawPiLabel = New-Object System.Windows.Forms.Label; $mackinawPiLabel.Location = New-Object System.Drawing.Point(20, 35); $mackinawPiLabel.Font = $labelFont; $mackinawPiLabel.AutoSize = $true;
    $mackinawDaLabel = New-Object System.Windows.Forms.Label; $mackinawDaLabel.Location = New-Object System.Drawing.Point(20, 65); $mackinawDaLabel.Font = $labelFont; $mackinawDaLabel.AutoSize = $true;
    $mobilePiLabel = New-Object System.Windows.Forms.Label; $mobilePiLabel.Location = New-Object System.Drawing.Point(20, 95); $mobilePiLabel.Font = $labelFont; $mobilePiLabel.AutoSize = $true;
    $mobileDaLabel = New-Object System.Windows.Forms.Label; $mobileDaLabel.Location = New-Object System.Drawing.Point(20, 125); $mobileDaLabel.Font = $labelFont; $mobileDaLabel.AutoSize = $true;
    $separator = New-Object System.Windows.Forms.Label; $separator.Location = New-Object System.Drawing.Point(20, 150); $separator.Text = "------------------------------------------"; $separator.AutoSize = $true;
    $grandTotalLabel = New-Object System.Windows.Forms.Label; $grandTotalLabel.Location = New-Object System.Drawing.Point(20, 170); $grandTotalLabel.Font = New-Object System.Drawing.Font('Segoe UI', 11, [System.Drawing.FontStyle]::Bold); $grandTotalLabel.AutoSize = $true;

    $summaryBox.Controls.AddRange(@($mackinawPiLabel, $mackinawDaLabel, $mobilePiLabel, $mobileDaLabel, $separator, $grandTotalLabel));

    # --- Function to update all totals ---
    $updateTotals = {
        # Helper function to prevent errors if a category has no entries
        $getSum = {
            param($filter)
            # DEBUG FIX: Added explicit return
            return ($Global:data | Where-Object $filter | Measure-Object -Property Hours -Sum).Sum;
        };

        $mackinawPiTotal = &$getSum -filter { $_.Location -eq 'MACKINAW' -and $_.Type -eq 'PI' };
        $mackinawDaTotal = &$getSum -filter { $_.Location -eq 'MACKINAW' -and $_.Type -eq 'DA' };
        $mobilePiTotal = &$getSum -filter { $_.Location -eq 'MOBILE' -and $_.Type -eq 'PI' };
        $mobileDaTotal = &$getSum -filter { $_.Location -eq 'MOBILE' -and $_.Type -eq 'DA' };
        $grandTotal = ($Global:data | Measure-Object -Property Hours -Sum).Sum;

        $mackinawPiLabel.Text = "MACKINAW (PI) Total:   $([int]$mackinawPiTotal)";
        $mackinawDaLabel.Text = "MACKINAW (DA) Total:   $([int]$mackinawDaTotal)";
        $mobilePiLabel.Text   = "MOBILE (PI) Total:     $([int]$mobilePiTotal)";
        $mobileDaLabel.Text   = "MOBILE (DA) Total:     $([int]$mobileDaTotal)";
        $grandTotalLabel.Text = "Overall Running Total: $([int]$grandTotal)";
    };

    # Update totals when the form loads and when the data list changes
    $Global:data.add_ListChanged({ &$updateTotals });
    $viewDataForm.add_Load({ &$updateTotals });

    # Back button
    $backButton = New-Object System.Windows.Forms.Button;
    $backButton.Location = New-Object System.Drawing.Point(135, 245);
    $backButton.Size = New-Object System.Drawing.Size(90, 30);
    $backButton.Text = 'Back';
    $backButton.Font = New-Object System.Drawing.Font('Segoe UI', 10, [System.Drawing.FontStyle]::Bold);
    $backButton.DialogResult = [System.Windows.Forms.DialogResult]::Cancel;
    $viewDataForm.Controls.Add($backButton);
    $viewDataForm.CancelButton = $backButton;

    $viewDataForm.ShowDialog();
}

# Start the application
Show-HomeScreen;
